{
  "version": 8,
  "name": "Basic Style",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "germany": {
      "type": "vector",
      "url": "mbtiles://germany.mbtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#e0e0e0" }
    },
    {
      "id": "water",
      "source": "germany",
      "source-layer": "water",
      "type": "fill",
      "paint": { "fill-color": "#a0c8f0" }
    },
    {
      "id": "waterway",
      "source": "germany",
      "source-layer": "waterway",
      "type": "line",
      "paint": { "line-color": "#a0c8f0", "line-width": 1 }
    },
    {
      "id": "landuse",
      "source": "germany",
      "source-layer": "landuse",
      "type": "fill",
      "paint": { "fill-color": "#c8e6c9", "fill-opacity": 0.6 }
    },
    {
      "id": "buildings",
      "source": "germany",
      "source-layer": "building",
      "type": "fill",
      "paint": { "fill-color": "#d1c4e9" }
    },
    {
      "id": "roads",
      "source": "germany",
      "source-layer": "transportation",
      "type": "line",
      "paint": {
        "line-color": "#ffffff",
        "line-width": 1.5
      }
    },
    {
      "id": "road-names",
      "source": "germany",
      "source-layer": "transportation_name",
      "type": "symbol",
      "layout": {
        "text-field": "{name}",
        "text-size": 11,
        "symbol-placement": "line",
        "text-rotation-alignment": "map",
        "text-font": ["Open Sans Regular","Arial Unicode MS Regular"]
      },
      "paint": {
        "text-color": "#555",
        "text-halo-color": "#fff",
        "text-halo-width": 1
      }
    },
    {
      "id": "boundaries",
      "source": "germany",
      "source-layer": "boundary",
      "type": "line",
      "paint": { "line-color": "#666666", "line-dasharray": [4,2] }
    },
    {
      "id": "places",
      "source": "germany",
      "source-layer": "place",
      "type": "symbol",
      "layout": { "text-field": "{name}", "text-size": 12 },
      "paint": { "text-color": "#333333" }
    }
  ]
}
