# URLs zu den lokalen OSM-Docker-Services
NOMINATIM_URL=http://localhost:7071
ORS_URL=http://localhost:8082
GRAPHHOPPER_URL=http://localhost:8989
TILESERVER_URL=http://localhost:8083
VROOM_URL=http://localhost:8084

# Docker Compose Pfad (für Start/Stop/Status und Setup)
