# Basis-Pfad für alle Laufzeit-Daten (Docker-Volumes, OSM-Importdaten, MBTiles)
# Kann im Setup-UI geändert werden – muss auf ein großes Laufwerk zeigen
OSM_DATA_ROOT=/mnt/ai-ssd/Joormann-Media-Jarvis-OSM-Lab

# URLs zu den lokalen OSM-Docker-Services
NOMINATIM_URL=http://localhost:7071
ORS_URL=http://localhost:8082
GRAPHHOPPER_URL=http://localhost:8989
TILESERVER_URL=http://localhost:8083
VROOM_URL=http://localhost:8084
OVERPASS_URL=http://localhost:7072

# Download-Quelle für NRW-PBF (Geofabrik)
GEOFABRIK_PBF_URL=https://download.geofabrik.de/europe/germany/nordrhein-westfalen-latest.osm.pbf

# MBTiles-Download-URL (leer lassen wenn manuell bereitgestellt)
MBTILES_URL=
